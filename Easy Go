/* ---------- CARRUSEL DE LOGOS ---------- */
.slider-logos {
  overflow: hidden;
  white-space: nowrap;
  width: 100%;
  box-sizing: border-box;
  padding: 10px 0;
}

.logos-track {
  display: inline-flex;
  animation: scroll-logos 40s linear infinite; /* más lento */
  gap: 80px;
}

.logos-track img {
  height: 100px; /* más grande */
  opacity: 0.5;
  filter: grayscale(100%); /* color gris */
  transition: transform 0.3s, filter 0.3s, opacity 0.3s;
}

.logos-track img:hover {
  transform: scale(1.08);
  opacity: 1;
  filter: grayscale(0%); /* vuelve a color al pasar el mouse */
}

@keyframes scroll-logos {
  from {
    transform: translateX(0);
  }
  to {
    transform: translateX(-50%);
  }
}
.slider-logos:hover .logos-track {
  animation-play-state: paused;
}

